{
  "name": "dsa-solvebook",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "scrape:local": "cd scraper && python main.py --username $LEETCODE_USERNAME",
